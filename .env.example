# ── Polymarket CLOB ────────────────────────────────────────────────────────────
CLOB_HOST=https://clob.polymarket.com
CLOB_API_KEY=your_api_key_here
CLOB_SECRET=your_secret_here
CLOB_PASSPHRASE=your_passphrase_here

# The Polymarket outcome token ID you are trading
POLY_TOKEN_ID=your_token_id_here

# ── Binance ────────────────────────────────────────────────────────────────────
BINANCE_SYMBOL=BTCUSDT

# ── Bot parameters ─────────────────────────────────────────────────────────────
BANKROLL_USD=1000
DRY_RUN=true                    # set to false to submit real orders

# Signal thresholds
MIN_EDGE=0.02                   # minimum edge in probability units
MIN_TICKS=2                     # consecutive ticks edge must persist

# Kelly sizer
KELLY_FRACTION=0.25             # fraction of full Kelly to use
MAX_POSITION_PCT=0.05           # hard cap: max % of bankroll per position

# Risk limits
MAX_DRAWDOWN_PCT=0.10           # halt at 10% drawdown from peak
MAX_DAILY_LOSS_PCT=0.05         # halt at 5% daily loss
MAX_NOTIONAL=500                # USD hard cap per order

# Polymarket polling
POLY_POLL_INTERVAL=0.5          # seconds between CLOB orderbook fetches

# Price → probability conversion
# BTC: logistic curve centred at BTC_TARGET_PRICE (scale = BTC_SCALE)
BTC_TARGET_PRICE=85000          # current rough BTC market price as centre
BTC_SCALE=5000                  # logistic scale factor (~1 std-dev in USD)

# ETH: same approach
ETH_TARGET_PRICE=2000
ETH_SCALE=200

# ── GitHub Issue tracker ───────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=your-username/your-repo
GITHUB_ISSUE=1                  # issue number to append stats comments to
